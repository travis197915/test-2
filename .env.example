# ── Repo paths (full paths on your machine) ───────────────────────────────────
AGENTIC_BACKEND_PATH=/path/to/agentic-backend
CLAIMS_BACKEND_PATH=/path/to/claims-backend
AUDIT_REVIEW_DASHBOARD_HITL_PATH=/path/to/audit-review-dashboard
CLAIMS_FRONTEND_DASHBOARD_PATH=/path/to/claims-frontend
MCP_SERVER_PATH=/path/to/claims-tools-mcp-server

# ── Orchestrator files ────────────────────────────────────────────────────────
DEPLOYMENT_REF_FILE=deployment-ref.txt

# ── Docker / volumes ──────────────────────────────────────────────────────────
USE_NAMED_VOLUMES=true
NETWORK_NAME=app-net
DATA_ROOT=~/docker-data

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_IMAGE=postgres:16
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=postgres
PG_AGENTIC_DB=agentic_flow_v2db
PG_CLAIMS_SCHEMA=claims_corebackend
PG_CLUSTER_DATABASES=postgres,agentic_flow_v2db,test_postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_IMAGE=redis:7
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_IMAGE=neo4j:5
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474
NEO4J_AUTH=neo4j/changeme
NEO4J_DATABASE=neo4j

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_IMAGE=mongo:7
MONGO_PORT=27017
MONGO_USER=admin
MONGO_PASSWORD=changeme
MONGO_DATABASE=sop_ingestion_v2

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_IMAGE=rabbitmq:3-management
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=changeme

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_IMAGE=uhc-storage-account:local
STORAGE_BUILD_PATH=storage-account
STORAGE_PORT=8080
STORAGE_ACCESS_KEY=local-access-key
STORAGE_SECRET=local-secret

# ── Agentic automatic post-steps ──────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:3000
